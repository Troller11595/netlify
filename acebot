  const resp = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1000,
      messages: [{ role: 'user', content: prompt }]
    })
  });
  if (!resp.ok) {
    const err = await resp.json().catch(() => ({}));
    throw new Error(err.error?.message || 'API error ' + resp.status);
  }
  const data = await resp.json();
  const text = data.content.map(c => c.text || '').join('');
  return JSON.parse(text.replace(/```json|```/g, '').trim());
}

async function addEmail() {
  const from = document.getElementById('n-from').value.trim();
  const subject = document.getElementById('n-subject').value.trim();
  const body = document.getElementById('n-body').value.trim();
  if (!from || !subject || !body) { showToast('err', 'Please fill in all fields.'); return; }
  if (!apiKey.startsWith('sk-ant-')) { showToast('err', 'Add your Anthropic API key first.'); return; }

  const btn = document.getElementById('classify-btn');
  btn.disabled = true; btn.textContent = 'Classifying...';

  const email = {
    id: nextId++, from, subject, body,
    category: 'Classifying', priority: 4, urgency: 'pending', risk: 'medium',
    analysis: null, draft: null,
    snoozed: false, snoozeLabel: '', sent: false, autoSent: false,
    time: new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }),
    classifying: true
  };
  emails.unshift(email);
  document.getElementById('n-from').value = '';
  document.getElementById('n-subject').value = '';
  document.getElementById('n-body').value = '';
  renderList();

  try {
    const r = await claudeClassify(from, subject, body);
    const e = emails.find(x => x.id === email.id);
    if (!e) return;
    e.category = r.category || 'General';
    e.priority = Math.min(4, Math.max(1, parseInt(r.priority) || 3));
    e.urgency = r.urgency || 'low';
    e.risk = r.risk || 'medium';
    e.analysis = r.analysis || 'No analysis available.';
    e.draft = r.draft || 'Thank you for reaching out. A team member will follow up shortly.';
    e.classifying = false;
    renderList();
    if (autoEnabled && e.risk === 'low' && !e.sent && !e.autoSent && !e.snoozed) {
      setTimeout(() => { e.autoSent = true; showToast('auto', 'Auto-sent to ' + e.from.split('<')[0].trim()); renderList(); }, 1000);
    }
  } catch (err) {
    const e = emails.find(x => x.id === email.id);
    if (e) { e.category = 'General'; e.priority = 4; e.urgency = 'low'; e.risk = 'medium'; e.analysis = 'Error: ' + err.message; e.draft = 'Thank you for your email. A team member will be in touch shortly.'; e.classifying = false; }
    showToast('err', 'Classification failed: ' + err.message);
    renderList();
  } finally {
    btn.disabled = false; btn.textContent = 'Classify with Claude →';
  }
}

function setSort(mode) {
  sortMode = mode;
  ['priority','time','cat'].forEach(m => document.getElementById('sort-'+m).classList.toggle('active', m === mode || (mode==='category'&&m==='cat')));
  if (mode === 'category') { document.getElementById('sort-cat').classList.add('active'); }
  renderList();
}

function toggleAuto() {
  autoEnabled = !autoEnabled;
  document.getElementById('auto-track').classList.toggle('on', autoEnabled);
}

function sorted() {
  const active = emails.filter(e => !e.sent && !e.autoSent && !e.snoozed);
  const snoozed = emails.filter(e => e.snoozed && !e.sent && !e.autoSent);
  const done = emails.filter(e => e.sent || e.autoSent);
  if (sortMode === 'priority') active.sort((a,b) => a.priority - b.priority);
  if (sortMode === 'time') active.sort((a,b) => b.id - a.id);
  if (sortMode === 'category') active.sort((a,b) => a.category.localeCompare(b.category));
  return { active, snoozed, done };
}

function emailRow(e) {
  const pLabel = e.classifying ? '?' : ['','P1','P2','P3','P4'][e.priority] || 'P4';
  const pClass = e.classifying ? 'p-pending' : ['','p1','p2','p3','p4'][e.priority] || 'p4';
  const cat = e.classifying ? 'Classifying…' : e.category;
  const catPill = e.classifying ? 'pill-pending' : 'pill-' + e.category;
  const uClass = e.classifying ? 'u-pending' : 'u-' + e.urgency;
  const cls = ['email-item', e.snoozed?'snoozed':'', e.autoSent?'auto-sent':'', e.classifying?'classifying':''].filter(Boolean).join(' ');
  const onclick = e.classifying ? '' : `onclick="selectEmail(${e.id})"`;
  return `<div class="${cls}" ${onclick}>
    <div class="pri-badge ${pClass}">${pLabel}</div>
    <div class="email-left">
      <div class="email-top"><span class="sender">${e.from.split('<')[0].trim()}</span><span class="etime">${e.time}</span></div>
      <div class="subject">${e.subject}</div>
      <div class="pill-row">
        <span class="pill ${catPill}">${cat}</span>
        ${e.classifying ? '<span class="pill pill-ai" style="animation:pulse 1.2s infinite">AI classifying</span>' : ''}
        ${e.snoozed ? `<span class="pill pill-snooze">⏱ ${e.snoozeLabel}</span>` : ''}
        ${e.autoSent ? '<span class="pill pill-auto">Auto-sent</span>' : ''}
        <div class="u-dot ${uClass}"></div>
      </div>
    </div>
  </div>`;
}

function renderList() {
  const { active, snoozed, done } = sorted();
  let html = '';
  const unread = active.filter(e => !e.classifying).length;
  document.getElementById('unread-chip').textContent = unread + ' unread';
  document.getElementById('s-total').textContent = emails.length;
  document.getElementById('s-handled').textContent = emails.filter(e => e.sent).length;
  document.getElementById('s-snoozed').textContent = emails.filter(e => e.snoozed).length;
  document.getElementById('s-auto').textContent = emails.filter(e => e.autoSent).length;
  if (!emails.length) { html = '<div class="empty"><span>✉</span>Add an email below to classify it</div>'; }
  else {
    if (active.length) { html += '<div class="section-head">Active</div>'; active.forEach(e => html += emailRow(e)); }
    if (snoozed.length) { html += '<div class="section-head">Snoozed</div>'; snoozed.forEach(e => html += emailRow(e)); }
    if (done.length) { html += '<div class="section-head">Handled</div>'; done.forEach(e => html += emailRow(e)); }
  }
  document.getElementById('email-list').innerHTML = html;
}

function selectEmail(id) {
  const e = emails.find(x => x.id === id);
  if (!e || e.classifying) return;
  selectedId = id; snoozeOpen = false;
  document.getElementById('list-view').style.display = 'none';
  document.getElementById('detail-view').style.display = 'block';
  document.getElementById('snooze-drop').style.display = 'none';
  document.getElementById('d-from').textContent = e.from;
  document.getElementById('d-subject').textContent = e.subject;
  document.getElementById('d-body').textContent = e.body;
  const cb = document.getElementById('d-cat-badge');
  cb.textContent = e.category; cb.className = 'risk-default';
  document.getElementById('d-analysis').textContent = e.analysis || '';
  document.getElementById('d-draft').textContent = e.draft || '';
  document.getElementById('edit-area').value = e.draft || '';
  const rb = document.getElementById('d-risk-badge');
  if (e.risk === 'low') { rb.textContent = 'Low risk — auto-sendable'; rb.className = 'risk-low'; }
  else if (e.risk === 'high') { rb.textContent = 'High risk — review required'; rb.className = 'risk-high'; }
  else { rb.textContent = 'Medium — review suggested'; rb.className = 'risk-med'; }
}

function goBack() {
  selectedId = null; snoozeOpen = false;
  document.getElementById('snooze-drop').style.display = 'none';
  document.getElementById('list-view').style.display = 'block';
  document.getElementById('detail-view').style.display = 'none';
  renderList();
}

function sendReply() {
  if (selectedId === null) return;
  const e = emails.find(x => x.id === selectedId);
  e.sent = true;
  showToast('send', 'Reply sent to ' + e.from.split('<')[0].trim());
  setTimeout(goBack, 1400);
}

function toggleSnooze() {
  snoozeOpen = !snoozeOpen;
  document.getElementById('snooze-drop').style.display = snoozeOpen ? 'block' : 'none';
}

function doSnooze(label) {
  if (selectedId === null) return;
  const e = emails.find(x => x.id === selectedId);
  e.snoozed = true; e.snoozeLabel = label; snoozeOpen = false;
  showToast('snooze', 'Snoozed until ' + label);
  setTimeout(goBack, 1400);
}

function showToast(type, msg) {
  const el = document.getElementById('t-' + type);
  if (!el) return;
  el.textContent = msg; el.style.display = 'block';
  setTimeout(() => el.style.display = 'none', 2400);
}

renderList();
</script>
</body>
</html>
